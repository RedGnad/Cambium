{
  "name": "@cambium/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:deploy:ci": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:generate:ci": "prisma generate --schema prisma/schema.prisma",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "gen:demo-keys": "tsx scripts/gen-demo-keys.ts",
    "seed:demo": "dotenv -e ../../.env -- tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@cambium/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^5.20.0",
    "@react-pdf/renderer": "^4.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "dotenv-cli": "^7.4.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
