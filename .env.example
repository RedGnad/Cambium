NODE_ENV=development

# URLs
APP_BASE_URL=http://localhost:3000
# Local development points directly to the Fastify API.
# On Vercel embedded API mode, leave API_BASE_URL unset.
# On Vercel split API mode, set it to https://<your-api-host>.
API_BASE_URL=http://localhost:4000

# Database
# Do not use localhost on Vercel. Use Neon/Supabase/Vercel Postgres/etc.
DATABASE_URL=postgresql://cambium:cambium@localhost:5432/cambium?schema=public

# Constellation Digital Evidence
# Supported modes: mock | live
CONSTELLATION_MODE=mock
# Production MainNet API. Required when CONSTELLATION_MODE=live.
CONSTELLATION_API_BASE_URL=https://de-api.constellationnetwork.io/v1
CONSTELLATION_API_KEY=
CONSTELLATION_ORG_ID=
CONSTELLATION_TENANT_ID=

# Demo signer (secp256k1, hex-encoded, 32 bytes)
# Generated by `pnpm --filter @cambium/api gen:demo-keys` — do NOT use in production.
DEMO_SIGNER_PRIVATE_KEY=
DEMO_SIGNER_PUBLIC_KEY=

# Storage
PDF_STORAGE_PATH=./storage/pdf
PRIVATE_STORAGE_PATH=./storage/private
